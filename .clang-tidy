# clang-tidy configuration for dns-encrypted-proxy
#
# Goal: catch real bugs (memory safety, undefined behavior, concurrency hazards,
# CERT C rules) without drowning in stylistic noise. Enabled categories cover
# things the GCC strict-warning set does not (e.g. analyzer-style checks, CERT
# rules, unbounded recursion). Disabled checks are either too noisy on idiomatic
# systems C or out of scope (C++/modernize/Google-style).

Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-misplaced-widening-cast,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-narrowing-conversions,
  -bugprone-reserved-identifier,
  -bugprone-suspicious-include,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -cert-err33-c,
  -cert-err34-c,
  -cert-msc30-c,
  -cert-msc50-cpp,
  -clang-analyzer-optin.performance.Padding,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-security.insecureAPI.strcpy,
  -concurrency-mt-unsafe,
  -performance-enum-size,
  -misc-include-cleaner,
  -misc-no-recursion,
  -misc-static-assert,
  -readability-avoid-nested-conditional-operator,
  -readability-avoid-unconditional-preprocessor-if,
  -readability-braces-around-statements,
  -readability-cognitive-complexity,
  -readability-else-after-return,
  -readability-function-cognitive-complexity,
  -readability-function-size,
  -readability-identifier-length,
  -readability-identifier-naming,
  -readability-isolate-declaration,
  -readability-magic-numbers,
  -readability-math-missing-parentheses,
  -readability-redundant-casting,
  -readability-suspicious-call-argument,
  -readability-uppercase-literal-suffix

WarningsAsErrors: ''

HeaderFilterRegex: '^src/.*\.h$'

FormatStyle: none

CheckOptions:
  bugprone-argument-comment.StrictMode: 1
  cert-dcl16-c.NewSuffixes: 'L;LL;LU;LLU'
  readability-identifier-naming.ConstantCase: lower_case
  readability-identifier-naming.EnumCase: CamelCase
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.GlobalConstantCase: lower_case
  readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
  readability-identifier-naming.StructCase: lower_case
  readability-identifier-naming.TypedefCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
